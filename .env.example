# тг токен от bot father
TELEGRAM_BOT_TOKEN=

# llm
GIGACHAT_CREDENTIALS=
GEMINI_API_KEY=
# эти не используются в yaml, но провайдеры такие есть, если есть ключи
OPENROUTER_API_KEY=
OPENAI_API_KEY=
